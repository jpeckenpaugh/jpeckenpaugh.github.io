{
  "mushy_01": {
    "title": "Once upon a time...",
    "continent": "base",
    "summary_pre": "A crow attacks a tiny mushroom in the clearing.",
    "summary_active": "Chase off the crow and learn basic magic from Mushy.",
    "summary_complete": "Quest complete.",
    "art_opponent": "mushroom_baby",
    "dialog": [
      "You hear a commotion. A young mushroom is being attacked by a large crow.",
      "You rush in and drive the crow away.",
      "Mushy thanks you and offers a magic mushroom tea to open your mind to basic spells.",
      "He teaches Strength to raise ATK/DEF and Life Boost to raise max HP.",
      "Cast Strength, then head into the forest to fight and recruit two more mushroom babies.",
      "With three mushrooms, the temple can fuse you into a stronger form."
    ],
    "requirements": {
      "flags_required": [],
      "level_min": 1
    },
    "objectives": [
      {
        "type": "fuse_followers",
        "follower_type": "mushroom_baby",
        "count": 3
      }
    ],
    "on_start_actions": [
      {
        "type": "show_message",
        "message": "Cast Strength from your spellbook, then head out to the Forest and find some opponents."
      },
      {
        "type": "set_flags",
        "flags": [
          "spell_life_boost_enabled",
          "spell_strength_enabled"
        ]
      },
      {
        "type": "set_recruit_only_types",
        "types": [
          "mushroom_baby"
        ]
      },
      {
        "type": "set_follower_cap_extra",
        "value": 2
      },
      {
        "type": "grant_follower",
        "follower": {
          "type": "mushroom_baby",
          "name": "Mushy",
          "count_as_recruit": true
        },
        "required": true
      }
    ],
    "on_complete_actions": [
      {
        "type": "clear_recruit_only_types"
      },
      {
        "type": "set_follower_cap",
        "value": 2
      },
      {
        "type": "set_flags",
        "flags": [
          "quest_mushy_01_complete"
        ]
      },
      {
        "type": "grant_xp",
        "amount": 100
      }
    ]
  },
